# Postgres connection string (Render Postgres, Neon, or local).
# Local example: postgres://postgres:postgres@localhost:5432/futurekey
DATABASE_URL=

# Resend API key (https://resend.com -> API Keys)
RESEND_API_KEY=

# From address. For testing without a verified domain use Resend's sandbox sender:
#   FutureKey <onboarding@resend.dev>
MAIL_FROM=FutureKey <onboarding@resend.dev>

# Shared secret the cron pinger must send to POST /cron/dispatch
CRON_SECRET=change-me

# Allowed browser origin for CORS (the frontend URL). Use * to allow any.
FRONTEND_ORIGIN=http://localhost:5173

# Port the API listens on
PORT=3001
